<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F9F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♻️ Detalle del Residuo"
            android:textColor="#1B5E20"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Edita la información o elimina el registro"
            android:textColor="#66796B"
            android:textSize="13sp" />

        <!-- Foto del reciclaje -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#E8F5E9"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/ivFotoResiduo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Foto del residuo"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvSinFoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📷\nEste registro no tiene foto"
                android:textColor="#66796B"
                android:textSize="14sp"
                android:visibility="gone" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Formulario -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView style="@style/EtiquetaDetalle" android:text="Categoría" />
                <Spinner
                    android:id="@+id/spCategoriaDet"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_spinner" />

                <TextView style="@style/EtiquetaDetalle" android:text="Cantidad" />
                <EditText
                    android:id="@+id/etCantidadDet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_campo"
                    android:inputType="numberDecimal"
                    android:padding="14dp"
                    android:textColor="#1B1F1C"
                    android:textSize="15sp" />

                <TextView style="@style/EtiquetaDetalle" android:text="Unidad" />
                <Spinner
                    android:id="@+id/spUnidadDet"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_spinner" />

                <TextView style="@style/EtiquetaDetalle" android:text="Origen" />
                <EditText
                    android:id="@+id/etOrigenDet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_campo"
                    android:padding="14dp"
                    android:textColor="#1B1F1C"
                    android:textSize="15sp" />

                <TextView style="@style/EtiquetaDetalle" android:text="Fecha" />
                <EditText
                    android:id="@+id/etFechaDet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:padding="14dp"
                    android:textColor="#1B1F1C"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btGuardarDet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#2E7D32"
            android:text="Guardar cambios"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btEliminarDet"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Eliminar registro"
            android:textColor="#C62828"
            style="@style/Widget.Material3.Button.TextButton" />

        <Button
            android:id="@+id/btVolverDet"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="Volver"
            android:textColor="#66796B"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>
</ScrollView>