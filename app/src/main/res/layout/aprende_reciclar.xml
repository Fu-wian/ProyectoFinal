<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F9F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Encabezado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 Aprende a Reciclar"
            android:textColor="#1B5E20"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Lee, aprende y pon a prueba tus conocimientos"
            android:textColor="#66796B"
            android:textSize="13sp" />

        <!-- Tarjeta: imagen + texto educativo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:contentDescription="Materiales reciclables"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dsiewe" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:padding="16dp"
                    android:text="El reciclaje es una de las herramientas más poderosas y accesibles que tenemos para proteger nuestro planeta. Al transformar materiales usados como el plástico, el vidrio y el papel en nuevos productos, reducimos la necesidad de extraer recursos naturales, disminuimos la basura en los vertederos, ahorramos energía y mitigamos la contaminación del aire y del agua. Reciclar a diario es un compromiso vital para un futuro más limpio y sostenible."
                    android:textColor="#37474F"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta: quiz -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvProgresoQuiz"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pregunta 1 de 5"
                    android:textColor="#66796B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPregunta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:text="¿Cuál de estos materiales tarda más en degradarse?"
                    android:textColor="#1B5E20"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgOpciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbOpcion1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#37474F"
                        android:textSize="14sp"
                        app:buttonTint="#2E7D32" />

                    <RadioButton
                        android:id="@+id/rbOpcion2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#37474F"
                        android:textSize="14sp"
                        app:buttonTint="#2E7D32" />

                    <RadioButton
                        android:id="@+id/rbOpcion3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#37474F"
                        android:textSize="14sp"
                        app:buttonTint="#2E7D32" />
                </RadioGroup>

                <TextView
                    android:id="@+id/tvRetroalimentacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnResponder"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#2E7D32"
                    android:text="Responder"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón volver -->
        <Button
            android:id="@+id/btnVolverAprende"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Volver"
            android:textColor="#66796B"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>
</ScrollView>