<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvTituloEcoSpots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Puntos de Reciclaje"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:gravity="center"
        android:padding="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:text="Los marcadores 📍 son puntos de recolección donde puedes llevar tus reciclables. Tócalos para ver qué materiales aceptan y cómo llegar. Mantén presionado el mapa para agregar un punto"
        android:textColor="#66796B"
        android:textSize="13sp" />
    <fragment
        android:id="@+id/mapEcoSpots"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />



</LinearLayout>