<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F9F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TinaEco ♻️"
            android:textColor="#2E7D32"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
        <!-- Encabezado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 Tu Impacto Ambiental"
            android:textColor="#1B5E20"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnSemanaAnterior"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Semana anterior"
                android:src="@drawable/baseline_chevron_left_24"
                app:tint="#2E7D32" />

            <TextView
                android:id="@+id/tvSemana"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Semana del ..."
                android:textColor="#66796B"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btnSemanaSiguiente"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Semana siguiente"
                android:src="@drawable/baseline_chevron_right_24"
                app:tint="#2E7D32" />
        </LinearLayout>

        <!-- Estado vacío -->
        <TextView
            android:id="@+id/tvVacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:text="Aún no registras residuos esta semana.\nToca + Agregar Residuos para empezar."
            android:textColor="#66796B"
            android:textSize="15sp"
            android:visibility="gone" />

        <!-- Contenido con datos -->
        <LinearLayout
            android:id="@+id/contenido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO: total de la semana -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#2E7D32"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Residuos registrados esta semana"
                        android:textColor="#C8E6C9"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCantidadResiduos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0.0 kg"
                        android:textColor="#FFFFFF"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvComparacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="#C8E6C9"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mini-cards: CO2 y árboles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💨 CO₂ evitado"
                            android:textColor="#66796B"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvcantidadCo2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0.0 kg"
                            android:textColor="#1B5E20"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEquivalenciaCo2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text=""
                            android:textColor="#66796B"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌳 Árboles"
                            android:textColor="#66796B"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvcantidadReciclada"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0"
                            android:textColor="#1B5E20"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDetalleReciclado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text=""
                            android:textColor="#66796B"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Gráfica semanal -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Residuos por día (kg)"
                        android:textColor="#1B5E20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:layout_marginTop="12dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:weightSum="7">

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValLun" style="@style/ValorBarra" />
                            <View android:id="@+id/barLun" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="L" />
                        </LinearLayout>

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValMar" style="@style/ValorBarra" />
                            <View android:id="@+id/barMar" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="M" />
                        </LinearLayout>

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValMie" style="@style/ValorBarra" />
                            <View android:id="@+id/barMie" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="X" />
                        </LinearLayout>

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValJue" style="@style/ValorBarra" />
                            <View android:id="@+id/barJue" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="J" />
                        </LinearLayout>

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValVie" style="@style/ValorBarra" />
                            <View android:id="@+id/barVie" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="V" />
                        </LinearLayout>

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValSab" style="@style/ValorBarra" />
                            <View android:id="@+id/barSab" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="S" />
                        </LinearLayout>

                        <LinearLayout style="@style/ColumnaGrafica">
                            <TextView android:id="@+id/tvValDom" style="@style/ValorBarra" />
                            <View android:id="@+id/barDom" style="@style/BarraDia" />
                            <TextView style="@style/DiaGrafica" android:text="D" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Desglose por categoría -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Por categoría"
                        android:textColor="#1B5E20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <Button
            android:id="@+id/btnAgregarResiduos"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2E7D32"
            android:text="+ Agregar Residuos"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>