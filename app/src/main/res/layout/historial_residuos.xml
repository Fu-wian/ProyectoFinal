<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F9F4"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Encabezado -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🗂️ Historial de Residuos"
        android:textColor="#1B5E20"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvContador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#66796B"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:text="Mantén presionado un registro para editarlo o eliminarlo"
        android:textColor="#66796B"
        android:textSize="13sp" />

    <!-- Filtro por categoría (FUERA de la card) -->
    <Spinner
        android:id="@+id/spFiltroCategoria"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_spinner" />

    <!-- Tarjeta con la lista (UN solo hijo adentro) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <ListView
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="#E0EDE0"
            android:dividerHeight="1dp"
            android:padding="8dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Botón volver -->
    <Button
        android:id="@+id/btnVolver"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#2E7D32"
        android:text="Volver"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:cornerRadius="16dp" />

</LinearLayout>